# Example Environment Configuration
# Copy to .env.development or .env.production — never commit real credentials.

NODE_ENV=development

# Server
PORT=3050
API_URL=http://localhost:3050
FRONTEND_URL=http://localhost:3050

# Storage: file = JSON files (default). mongodb is legacy-only (not mounted).
STORAGE_MODE=file

# Live score sync (local writable mode polls upstream; Vercel refreshes on /get/live)
LIVE_SYNC_ENABLED=true
LIVE_SYNC_URL=https://worldcup26.ir
LIVE_SYNC_INTERVAL_MS=30000

# Swagger (/api-docs) — enabled by default in development
ENABLE_SWAGGER=true

# Rate limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=500

# CORS (* for dev; comma-separated origins in production)
CORS_ORIGINS=*

# Live payload validation (optional — defaults match World Cup 2026)
# LIVE_VALIDATE_EXPECTED_GAMES=104
# LIVE_VALIDATE_EXPECTED_GROUPS=12
# LIVE_VALIDATE_MIN_GAME_RATIO=0.75
# LIVE_VALIDATE_STRICT_GROUPS=true
# LIVE_VALIDATE_GROUP_PATTERN=^[A-L]$
