{
  "name": "worldcup2026-api",
  "version": "1.0.5",
  "description": "Free open-source REST API for FIFA World Cup 2026 with file-backed live scores, match schedule, group standings, 48 teams, 16 stadiums, and real-time updates.",
  "main": "index.js",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env NODE_ENV=development PORT=3051 node index.js",
    "prod": "cross-env NODE_ENV=production node index.js",
    "start:dev": "cross-env NODE_ENV=development PORT=3051 node index.js",
    "start:prod": "cross-env NODE_ENV=production node index.js",
    "export:data": "node -e \"require('./data/store').exportPublicData()\"",
    "test:load": "node load-test.js"
  },
  "keywords": [
    "fifa-world-cup-2026",
    "world-cup-api",
    "football-api",
    "soccer-api",
    "free-api",
    "free-football-api",
    "free-soccer-api",
    "free-sports-api",
    "live-scores",
    "live-score-api",
    "live-results",
    "rest-api",
    "express",
    "node",
    "swagger",
    "openapi",
    "real-time-scores",
    "sports-api",
    "sports-data",
    "48-teams",
    "usa-mexico-canada",
    "world-cup-schedule",
    "world-cup-fixtures",
    "world-cup-standings",
    "world-cup-groups",
    "football-data",
    "soccer-data",
    "open-source"
  ],
  "author": "jp2435",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.4",
    "body-parser": "^1.19.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.17.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^2.0.15"
  }
}
